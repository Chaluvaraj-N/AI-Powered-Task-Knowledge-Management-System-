# Copy this file to .env for the AI-Powered Task & Knowledge Management System and fill in real values before running the backend.

# --- Database -----------------------------------------------------------
# MySQL is mandatory per the assignment. Example:
#   DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/task_ai_db
# If left unset, the app falls back to a local SQLite file (storage/app.db)
# so it can be run instantly for a quick demo without installing MySQL.
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/task_ai_db

# --- JWT ------------------------------------------------------------------
JWT_SECRET_KEY=replace_with_a_long_random_secret_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
